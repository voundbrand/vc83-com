{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sevenlayers.ai/schemas/clara-germanclaw/case-packet-v1.json",
  "title": "Clara GermanClaw MVP Case Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caller_profile",
    "legal_issue_summary",
    "urgency_level",
    "deadlines_and_risks",
    "recommended_next_actions",
    "operator_handoff_packet",
    "metadata"
  ],
  "properties": {
    "caller_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "callback_number",
        "preferred_callback_window",
        "preferred_language",
        "consent",
        "org_isolation"
      ],
      "properties": {
        "full_name": { "type": "string", "minLength": 1 },
        "callback_number": { "type": "string", "minLength": 3 },
        "email": { "type": ["string", "null"], "format": "email" },
        "preferred_callback_window": { "type": "string", "minLength": 1 },
        "preferred_language": { "type": "string", "enum": ["de", "en"] },
        "caller_type": { "type": "string", "enum": ["client", "prospect", "third_party", "unknown"] },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ai_disclosure_acknowledged",
            "recording_notice_provided",
            "purpose_notice_provided"
          ],
          "properties": {
            "ai_disclosure_acknowledged": { "type": "boolean" },
            "recording_notice_provided": { "type": "boolean" },
            "purpose_notice_provided": { "type": "boolean" }
          }
        },
        "org_isolation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["org_id", "tenant_id"],
          "properties": {
            "org_id": { "type": "string", "minLength": 1 },
            "tenant_id": { "type": "string", "minLength": 1 },
            "matter_scope_id": { "type": ["string", "null"] }
          }
        }
      }
    },
    "legal_issue_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["practice_area", "caller_goal", "factual_summary"],
      "properties": {
        "practice_area": {
          "type": "string",
          "enum": ["arbeitsrecht", "familienrecht", "mietrecht", "strafrecht", "other"]
        },
        "caller_goal": { "type": "string", "minLength": 1 },
        "factual_summary": { "type": "string", "minLength": 1 },
        "transcript_excerpt": { "type": ["string", "null"] }
      }
    },
    "urgency_level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "rationale", "immediate_safety_risk"],
      "properties": {
        "level": { "type": "string", "enum": ["low", "normal", "high", "emergency"] },
        "rationale": { "type": "string", "minLength": 1 },
        "immediate_safety_risk": { "type": "boolean" }
      }
    },
    "deadlines_and_risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "description", "risk_level"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["deadline", "safety", "evidence", "procedural", "other"]
          },
          "description": { "type": "string", "minLength": 1 },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "due_at_iso8601": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "owner", "priority"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "owner": {
            "type": "string",
            "enum": [
              "intake_structuring_worker",
              "urgency_triage_worker",
              "followup_action_planner_worker",
              "operator",
              "lawyer"
            ]
          },
          "priority": { "type": "string", "enum": ["p0", "p1", "p2", "p3"] },
          "due_at_iso8601": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "operator_handoff_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_reason",
        "summary_for_operator",
        "callback_script_hint",
        "missing_information",
        "queue_route"
      ],
      "properties": {
        "handoff_reason": {
          "type": "string",
          "enum": ["standard_followup", "priority_deadline", "emergency_signal", "insufficient_data"]
        },
        "summary_for_operator": { "type": "string", "minLength": 1 },
        "callback_script_hint": { "type": "string", "minLength": 1 },
        "missing_information": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "queue_route": {
          "type": "string",
          "enum": ["kanzlei_intake_default", "kanzlei_intake_priority", "kanzlei_intake_emergency"]
        }
      }
    },
    "worker_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worker_name", "worker_version", "contract_version"],
      "properties": {
        "worker_name": { "type": "string" },
        "worker_version": { "type": "string", "minLength": 1 },
        "contract_version": { "type": "string", "const": "1.0.0" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "captured_at_iso8601",
        "purpose_limitation",
        "retention_marker"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "captured_at_iso8601": { "type": "string", "format": "date-time" },
        "purpose_limitation": {
          "type": "string",
          "enum": ["legal_intake_and_callback_only"]
        },
        "retention_marker": {
          "type": "string",
          "enum": ["mvp_kanzlei_90d"]
        },
        "source": { "type": "string", "enum": ["clara_germanclaw_mvp"] }
      }
    }
  }
}
