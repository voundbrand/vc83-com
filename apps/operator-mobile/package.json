{
  "name": "l4yercak3-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ./scripts/require-supported-node.mjs expo-start && expo start",
    "android": "node ./scripts/require-supported-node.mjs expo-run-android && expo run:android",
    "ios": "node ./scripts/require-supported-node.mjs expo-run-ios && expo run:ios",
    "web": "node ./scripts/require-supported-node.mjs expo-start-web && expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "icons:check": "node ./scripts/check-ios-assets.mjs",
    "ios:preflight": "node ./scripts/require-supported-node.mjs ios-preflight && npm run typecheck && npm run icons:check",
    "ci:ios:preflight": "npm run ios:preflight",
    "credentials:ios": "npx eas-cli credentials --platform ios",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:ios:production": "npx eas-cli submit --platform ios --profile production",
    "deploy:testflight": "npx eas-cli build --platform ios --profile production --auto-submit"
  },
  "engines": {
    "node": ">=20 <24"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@tamagui/animations-react-native": "^1.144.0",
    "@tamagui/babel-plugin": "^1.144.0",
    "@tamagui/config": "^1.144.0",
    "@tamagui/font-inter": "^1.144.0",
    "@tamagui/lucide-icons": "^1.144.0",
    "@tamagui/react-native-media-driver": "^1.144.0",
    "@tamagui/shorthands": "^1.144.0",
    "@tamagui/themes": "^1.144.0",
    "babel-preset-expo": "^54.0.9",
    "expo": "~54.0.31",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "^18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "^14.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "^8.0.11",
    "expo-localization": "^17.0.8",
    "expo-router": "^6.0.21",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-speech": "^14.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-svg": "^15.15.1",
    "react-native-worklets": "^0.7.0",
    "react-native-worklets-core": "^1.6.2",
    "tailwindcss": "^3.4.19",
    "tamagui": "^1.144.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
