# OpenClaw Hetzner EU-MVP server env template
# Path suggestion on host: /opt/vc83-com/apps/nemoclaw-kanzlei-eu/repos/openclaw/.env

# Required
OPENCLAW_GATEWAY_TOKEN=replace-with-long-random-token
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Runtime bind profile
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_TZ=Europe/Berlin

# Optional
ELEVENLABS_API_KEY=replace-if-voice-enabled

# Optional image override
# OPENCLAW_IMAGE=openclaw:local
