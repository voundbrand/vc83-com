# Local OpenClaw Docker dev environment (example)
# Copy to: local-openclaw.env and fill secrets.

OPENCLAW_GATEWAY_TOKEN=replace-with-long-random-token
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_TZ=Europe/Berlin

OPENCLAW_CONFIG_DIR=/Users/foundbrand_001/.openclaw
OPENCLAW_WORKSPACE_DIR=/Users/foundbrand_001/.openclaw/workspace

# Pick one provider path for local testing.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
