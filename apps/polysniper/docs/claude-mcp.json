{
  "inputs": [
    {
      "id": "api_token",
      "type": "promptString",
      "description": "Geben Sie Ihr Hostinger API-Token ein (erforderlich)"
    }
  ],
  "servers": {
    "hostinger-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "hostinger-api-mcp@latest"
      ],
      "env": {
        "API_TOKEN": "${api_token}"
      }
    }
  }
}
