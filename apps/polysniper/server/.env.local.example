# Copy to .env.local for local Docker runtime.
# Do not commit .env.local.

# Server binding
PSNP_SERVER_HOST=0.0.0.0
PSNP_SERVER_PORT=8787

# Runtime mode contract
PSNP_RUNTIME_MODE=paper_sim
PSNP_TRADING_KILL_SWITCH=0

# Execution profile (deny-by-default for live trading)
PSNP_EXECUTION_PROFILE_ID=default_profile
PSNP_EXECUTION_PROFILE_STATUS=SIM_ONLY
PSNP_EXECUTION_PROFILE_VENUE=polymarket
PSNP_EXECUTION_PROFILE_ENTITY=
PSNP_EXECUTION_PROFILE_KYC_JURISDICTION=
PSNP_EXECUTION_PROFILE_OPERATOR_LOCATION=
PSNP_EXECUTION_PROFILE_BANKING_JURISDICTIONS=
PSNP_EXECUTION_PROFILE_AGENT_INTENTS_ENABLED=0
PSNP_AGENT_INTENTS_GLOBAL_ENABLED=1
PSNP_AGENT_INTENTS_REQUIRE_APPROVAL=1

# Optional explicit paths (defaults are usually sufficient)
# PSNP_DATA_DIR=/app/server/data
# PSNP_KILL_SWITCH_FLAG_PATH=/app/.runtime/kill-switch.flag

# Risk profile defaults (from master plan v1)
MAX_TRADE_NOTIONAL_USDC=15
MAX_DAILY_NOTIONAL_USDC=60
MAX_OPEN_RISK_USDC=45
MAX_OPEN_POSITIONS=4
MIN_EDGE_PCT=3
MIN_CONFIDENCE=62
PSNP_PREPAID_BALANCE_USD=300
PSNP_RESERVE_FLOOR_USD=40

# Model policy target
PSNP_MODEL_TARGET=claude-opus-2.4
PSNP_MODEL_PROVIDER=anthropic
PSNP_MODEL_CONFIDENCE_THRESHOLD=0.62

# Polymarket adapter settings (real adapters enabled, live submit disabled by default)
PSNP_POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
PSNP_POLY_CLOB_BASE_URL=https://clob.polymarket.com
PSNP_POLY_CLOB_ORDER_PATH=/order
PSNP_POLY_PUBLIC_GEO_PATH=/closed-only
PSNP_POLY_REQUEST_TIMEOUT_MS=6000
PSNP_PROVIDER_RETRY_CEILING=2
PSNP_ENABLE_LIVE_EXECUTION=0
PSNP_POLY_CHAIN_ID=137
PSNP_POLY_SIGNATURE_TYPE=1
PSNP_POLY_USE_SERVER_TIME=1
PSNP_POLY_REQUIRE_OPEN_ONLY=1
PSNP_POLY_LIVE_ORDER_TYPE=FOK
PSNP_POLY_LIVE_POST_ONLY=0
PSNP_POLY_LIVE_DEFER_EXECUTION=0
PSNP_POLY_DERIVE_API_CREDS=1

# Required for authenticated live submit path (keep empty for paper/staging defaults)
# PSNP_POLY_WALLET_PRIVATE_KEY=
# PSNP_POLY_FUNDER_ADDRESS=

# Preferred static L2 creds for live submit path (if omitted and derive is enabled, SDK derives creds)
# PSNP_POLY_CLOB_API_KEY=
# PSNP_POLY_CLOB_API_SECRET=
# PSNP_POLY_CLOB_PASSPHRASE=

# Optional geo token and legacy bearer token
# PSNP_POLY_GEO_BLOCK_TOKEN=
# PSNP_POLY_BEARER_TOKEN=
