{
  "name": "compliance-engine",
  "version": "0.1.0",
  "private": true,
  "description": "DSGVO/GDPR compliance sidecar for OpenClaw/NemoClaw AI agent instances",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "node --import tsx server/index.ts",
    "build": "tsc",
    "start:prod": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "better-sqlite3": "^11.8.1",
    "yaml": "^2.7.1",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
