{
  "name": "l4yercak3-com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "agents:catalog:audit": "bash scripts/ci/check-agent-catalog-drift.sh",
    "agents:catalog:audit:blocking": "AGENT_CATALOG_AUDIT_BLOCKING=1 bash scripts/ci/check-agent-catalog-drift.sh",
    "agents:catalog:sync": "AGENT_CATALOG_AUDIT_FUNCTION=internal.ai.agentCatalogSync.runScheduledSyncApply AGENT_CATALOG_INCLUDE_DOCS_SNAPSHOT_EXPORT=1 bash scripts/ci/check-agent-catalog-drift.sh",
    "mobile:start": "npm --prefix apps/operator-mobile run start",
    "mobile:typecheck": "npm --prefix apps/operator-mobile run typecheck",
    "mobile:lint": "npm --prefix apps/operator-mobile run lint",
    "lint": "eslint src/ convex/ scripts/i18n/ --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e:mobile": "playwright test -c playwright.mobile.config.ts",
    "test:e2e:mobile:headed": "playwright test -c playwright.mobile.config.ts --headed",
    "test:e2e:mobile:auth": "playwright test -c playwright.mobile.auth.config.ts",
    "test:e2e:mobile:auth:headed": "playwright test -c playwright.mobile.auth.config.ts --headed",
    "test:e2e:desktop": "playwright test -c playwright.desktop.config.ts",
    "test:e2e:desktop:headed": "playwright test -c playwright.desktop.config.ts --headed",
    "test:e2e:onboarding": "playwright test -c playwright.onboarding.config.ts",
    "test:e2e:shell-parity": "npm run test:e2e:desktop && npm run test:e2e:mobile",
    "test:e2e:visual": "playwright test -c playwright.visual.config.ts",
    "test:e2e:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:unit": "vitest run tests/unit",
    "test:unit:tool-foundry": "vitest run tests/unit/ai/toolFoundryContracts.test.ts",
    "test:i18n": "vitest run tests/unit/i18n",
    "test:integration": "vitest run tests/integration",
    "test:e2e:atx": "playwright test -c playwright.atx.config.ts",
    "test:e2e:atx:headed": "playwright test -c playwright.atx.config.ts --headed",
    "test:e2e:atx:ui": "playwright test -c playwright.atx.config.ts --ui",
    "test:e2e:checkout:transactional": "playwright test -c playwright.transactional.config.ts",
    "test:e2e:fnd-001": "playwright test -c playwright.founder.config.ts --grep \"FND-001\"",
    "test:e2e:fnd-002": "playwright test -c playwright.founder.config.ts --grep \"FND-002\"",
    "test:e2e:fnd-003": "playwright test -c playwright.founder.config.ts --grep \"FND-003\"",
    "test:e2e:fnd-004": "playwright test -c playwright.founder.config.ts --grep \"FND-004\"",
    "test:e2e:fnd-005": "playwright test -c playwright.founder.config.ts --grep \"FND-005\"",
    "test:e2e:fnd-006": "playwright test -c playwright.founder.config.ts --grep \"FND-006\"",
    "test:e2e:fnd-007": "playwright test -c playwright.fnd-007.config.ts",
    "test:e2e:founder": "playwright test -c playwright.founder.config.ts",
    "rehearsal:founder:aggregate": "node scripts/rehearsal/build-founder-rehearsal-aggregate.mjs",
    "demo:fnd-007": "npm run test:e2e:fnd-007",
    "demo:founder": "npm run test:e2e:founder && npm run rehearsal:founder:aggregate",
    "test:permissions": "vitest run tests/unit/permissions",
    "test:roles": "vitest run tests/unit/roles",
    "test:unit:dom": "vitest run -c vitest.dom.config.ts",
    "test:unit:agent-control:dom": "vitest run -c vitest.dom.config.ts tests/unit/ai/agentControlCenterTab.clickthrough.dom.test.ts",
    "test:model": "npx tsx scripts/test-model-validation.ts",
    "model:gate:audit": "MODEL_RELEASE_GATE_MODE=audit node --import tsx scripts/ci/model-release-gate-audit.ts",
    "model:gate:enforce": "MODEL_RELEASE_GATE_MODE=enforce node --import tsx scripts/ci/model-release-gate-audit.ts",
    "docs:guard": "bash scripts/ci/check-docs-guard.sh",
    "tool-foundry:guard": "bash scripts/ci/check-tool-foundry-guard.sh",
    "ai:usage:guard": "bash scripts/ci/check-ai-usage-metering.sh",
    "ai:economics:guard": "bash scripts/ci/check-ai-economics-contract.sh",
    "i18n:audit": "bash scripts/ci/check-i18n-audit.sh",
    "i18n:namespace:budget": "bash scripts/ci/check-i18n-namespace-load-budget.sh",
    "ui:legacy:guard": "bash scripts/ci/check-legacy-style-introductions.sh",
    "ui:design:guard": "bash scripts/ci/check-ui-design-drift.sh",
    "ui:showcase:guard": "bash scripts/ci/check-ui-showcase-enforcement.sh",
    "ui:principles:ci": "npm run ui:design:guard && npm run ui:showcase:guard && npm run test:e2e:visual"
