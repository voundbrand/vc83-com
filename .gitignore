# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kiro directory (AI agent working files)
.kiro/

# kiro projects for reference (large files, local only)
.kiro/projects_for_reference/

# clerk configuration (can include secrets)
/.clerk/

# playwright MCP debug logs
.playwright-mcp/

.env.local

# Expo operator mobile local artifacts (keep ios/android source in VCS; ignore only generated/local outputs)
apps/operator-mobile/node_modules/
apps/operator-mobile/.expo/
apps/operator-mobile/.expo-shared/
apps/operator-mobile/*.log
apps/operator-mobile/npm-debug.log*
apps/operator-mobile/yarn-debug.log*
apps/operator-mobile/pnpm-debug.log*
apps/operator-mobile/android/.gradle/
apps/operator-mobile/android/app/build/
apps/operator-mobile/ios/build/
apps/operator-mobile/ios/Pods/

# local agent and scratch workspace artifacts
/.claude/settings.json
/.claude/worktrees/
/Library/

# local QA output and temp files
/test-results/
/tmp/

# local screenshot exports
/screenshot-*.png
/nothing-homepage-full.png
